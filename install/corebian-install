#!/bin/bash
# corebian-install --- Install the running Corebian system to the internal eMMC.
#
# METHOD: "old-school" factory-partition reuse (per 7Ji's aminstall).
# e900v22c-class boxes (like Phicomm / Xiaomi) have a locked / proprietary Amlogic
# partition table that ampart CANNOT modify -- the stock u-boot won't honor the
# changes, so any repartitioned FAT is invisible to `fatload mmc`. Instead we REUSE
# two existing factory Amlogic named partitions:
#   - a FAT "boot" partition (default /dev/system) for cfgload + kernel.img + dtb.img
#   - an ext4 "rootfs" partition (default /dev/data) for the root filesystem
# The box env's cfgloademmc scans mmc 1:1..1F for `cfgload` -> bootm. Because these are
# FACTORY partitions, the stock u-boot reads them fine (unlike ampart-created ones).
#
# Requires assets bundled in the rootfs: /usr/lib/corebian/boot/{kernel.img,dtb.img,cfgload.txt,board.conf}
set -e
[ "$(id -u)" = 0 ] || { echo "Must run as root"; exit 1; }

BOOTSRC="/usr/lib/corebian/boot"
DIR="/mnt/.corebian-install"
[ -f "$BOOTSRC/board.conf" ] && . "$BOOTSRC/board.conf"
BOOT_PART="${EMMC_BOOT_PART:-/dev/system}"   # factory FAT partition for boot files
ROOT_PART="${EMMC_ROOT_PART:-/dev/data}"     # factory partition for the rootfs

echo "========== Corebian eMMC Installer (old-school) =========="
for t in mkfs.vfat mkfs.ext4 rsync mkimage; do command -v $t >/dev/null || { echo "[x] missing tool: $t"; exit 1; }; done
for f in kernel.img dtb.img cfgload.txt; do [ -f "$BOOTSRC/$f" ] || { echo "[x] missing asset: $BOOTSRC/$f"; exit 1; }; done
[ -b "$BOOT_PART" ] && [ -b "$ROOT_PART" ] || { echo "[x] factory partitions $BOOT_PART / $ROOT_PART not found"; exit 1; }
case "$(findmnt -no SOURCE / 2>/dev/null)" in "$BOOT_PART"|"$ROOT_PART") echo "[x] Already running from eMMC."; exit 1;; esac

echo "!!! WARNING: this reformats $BOOT_PART (-> FAT boot) and $ROOT_PART (-> ext4 rootfs),"
echo "    wiping internal Android. IRREVERSIBLE! (Stock u-boot / env untouched; USB boot is fallback.)"
printf "Type YES (uppercase) to continue: "; read -r ok; [ "$ok" = "YES" ] || { echo "Aborted."; exit 1; }

echo "[1/3] Format $BOOT_PART (FAT32) + $ROOT_PART (ext4)"
umount "$BOOT_PART" "$ROOT_PART" 2>/dev/null || true
mkfs.vfat -F 32 -n COREBIAN "$BOOT_PART" >/dev/null
mkfs.ext4 -F -q -L rootfs "$ROOT_PART"

echo "[2/3] Copy running rootfs -> $ROOT_PART (a few minutes)"
mkdir -p "$DIR"; mount "$ROOT_PART" "$DIR"
rsync -aHAX \
  --exclude='/proc/*' --exclude='/sys/*' --exclude='/dev/*' --exclude='/run/*' \
  --exclude='/tmp/*' --exclude='/mnt/*' --exclude='/media/*' --exclude='/lost+found' \
  / "$DIR/"
mkdir -p "$DIR"/{proc,sys,dev,run,tmp,mnt,media,boot}
printf '%s  /  ext4  defaults,noatime,errors=remount-ro  0 1\n' "$ROOT_PART" > "$DIR/etc/fstab"
sync; umount "$DIR"

echo "[3/3] Write bootm boot assets -> $BOOT_PART"
mount "$BOOT_PART" "$DIR"
cp "$BOOTSRC/kernel.img" "$BOOTSRC/dtb.img" "$DIR/"
sed "s#setenv bootargs \"#setenv bootargs \"corebian.root=$ROOT_PART #" "$BOOTSRC/cfgload.txt" > /tmp/.cfgload_emmc.txt
mkimage -A arm -O linux -T script -C none -n cfgload -d /tmp/.cfgload_emmc.txt "$DIR/cfgload" >/dev/null
rm -f /tmp/.cfgload_emmc.txt; sync; umount "$DIR"; rmdir "$DIR" 2>/dev/null || true

echo
echo "Done. Power off, REMOVE the USB drive, then power on."
echo "The box env's cfgloademmc will find cfgload on $BOOT_PART -> bootm -> Corebian (root on $ROOT_PART)."
echo "If it fails, plug the Corebian USB back in to boot normally (fallback)."
