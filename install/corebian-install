#!/bin/bash
# corebian-install --- Install the running Corebian system to the internal eMMC.
#
# Unlike ophub's armbian-install: these boxes' stock u-boot only has `bootm`, not `booti`,
# so the boot chain uses bootm (the box env's cfgloademmc scans eMMC for cfgload -> bootm).
# The partitioning flow follows ophub (ampart shrinks the Amlogic EPT, parted creates the
# MBR boot/root partitions, dd preserves the stock u-boot); only the files written to the
# BOOT partition are replaced with the bootm variant.
#
# Requires assets bundled in the rootfs: /usr/lib/corebian/boot/{kernel.img,dtb.img,cfgload.txt,board.conf}
set -e
[ "$(id -u)" = 0 ] || { echo "Must run as root"; exit 1; }

DEV_EMMC="/dev/mmcblk0"
BOOTSRC="/usr/lib/corebian/boot"
DIR="/mnt/.corebian-install"
UBOOT_BAK="/usr/lib/u-boot/mybox-bootloader.img"

echo "========== Corebian eMMC Installer =========="
[ -b "$DEV_EMMC" ] || { echo "[x] eMMC not found: $DEV_EMMC"; exit 1; }
for t in ampart parted mkfs.vfat mkfs.ext4 rsync mkimage; do command -v $t >/dev/null || { echo "[x] missing tool: $t"; exit 1; }; done
for f in kernel.img dtb.img cfgload.txt; do [ -f "$BOOTSRC/$f" ] || { echo "[x] missing asset: $BOOTSRC/$f"; exit 1; }; done
# Board-specific eMMC offsets (hardware quirks such as first N MiB not writable)
[ -f "$BOOTSRC/board.conf" ] && . "$BOOTSRC/board.conf"
BLANK1="${EMMC_BLANK1:-117}"; BOOTSZ="${EMMC_BOOT:-512}"; BLANK2="${EMMC_BLANK2:-0}"
case "$(findmnt -no SOURCE / 2>/dev/null)" in ${DEV_EMMC}*) echo "[x] Already running from eMMC."; exit 1;; esac

echo "!!! WARNING: this repartitions $DEV_EMMC and wipes internal Android. IRREVERSIBLE!"
echo "    (Stock u-boot and USB boot remain as fallback -- not a hard brick.)"
printf "Type YES (uppercase) to continue: "; read -r ok; [ "$ok" = "YES" ] || { echo "Aborted."; exit 1; }

echo "[1/6] Back up stock bootloader (first 4M)"
mkdir -p "$(dirname "$UBOOT_BAK")"
[ -f "$UBOOT_BAK" ] || dd if="$DEV_EMMC" of="$UBOOT_BAK" bs=1M count=4 conv=fsync 2>/dev/null

echo "[2/6] ampart: shrink Amlogic EPT"
for i in $(seq 1 30); do umount -f ${DEV_EMMC}p$i 2>/dev/null || true; done
ampart "$DEV_EMMC" --mode dclone data::-1:4 >/dev/null 2>&1 || true

echo "[3/6] parted: create MBR -- boot(fat32, ${BLANK1}->$((BLANK1+BOOTSZ-1))MiB) + root(ext4)"
parted -s "$DEV_EMMC" mklabel msdos
parted -s "$DEV_EMMC" mkpart primary fat32 ${BLANK1}MiB $((BLANK1+BOOTSZ-1))MiB
parted -s "$DEV_EMMC" mkpart primary ext4  $((BLANK1+BOOTSZ+BLANK2))MiB 100%
# After ampart touches the Amlogic EPT, partprobe often does not take effect;
# force a re-read with blockdev / partx.
partprobe "$DEV_EMMC" 2>/dev/null || true
blockdev --rereadpt "$DEV_EMMC" 2>/dev/null || true
partx -a "$DEV_EMMC" 2>/dev/null || true
sleep 3
PART_BOOT="${DEV_EMMC}p1"; PART_ROOT="${DEV_EMMC}p2"
[ -b "$PART_BOOT" ] && [ -b "$PART_ROOT" ] || { echo "[x] $PART_BOOT/$PART_ROOT not present"; exit 1; }

echo "[4/6] Format + copy rootfs -> $PART_ROOT (a few minutes)"
mkfs.vfat -F 32 -n BOOT_EMMC "$PART_BOOT" >/dev/null
mkfs.ext4 -F -q -L ROOTFS_EMMC "$PART_ROOT"
mkdir -p "$DIR"; mount "$PART_ROOT" "$DIR"
rsync -aHAX \
  --exclude='/proc/*' --exclude='/sys/*' --exclude='/dev/*' --exclude='/run/*' \
  --exclude='/tmp/*' --exclude='/mnt/*' --exclude='/media/*' --exclude='/lost+found' \
  / "$DIR/"
mkdir -p "$DIR"/{proc,sys,dev,run,tmp,mnt,media,boot}
printf '%s  /  ext4  defaults,noatime,errors=remount-ro  0 1\n' "$PART_ROOT" > "$DIR/etc/fstab"
sync; umount "$DIR"

echo "[5/6] Write bootm boot assets -> $PART_BOOT"
mount "$PART_BOOT" "$DIR"
cp "$BOOTSRC/kernel.img" "$BOOTSRC/dtb.img" "$DIR/"
sed "s#setenv bootargs \"#setenv bootargs \"corebian.root=$PART_ROOT #" "$BOOTSRC/cfgload.txt" > /tmp/.cfgload_emmc.txt
mkimage -A arm -O linux -T script -C none -n cfgload -d /tmp/.cfgload_emmc.txt "$DIR/cfgload" >/dev/null
rm -f /tmp/.cfgload_emmc.txt; sync; umount "$DIR"; rmdir "$DIR" 2>/dev/null || true

echo "[6/6] Restore stock u-boot (last step: only sector 0, keeps MBR table; avoids losing partition nodes mid-run)"
dd if="$UBOOT_BAK" of="$DEV_EMMC" conv=fsync bs=1 count=444 2>/dev/null
dd if="$UBOOT_BAK" of="$DEV_EMMC" conv=fsync bs=512 skip=1 seek=1 2>/dev/null
sync

echo "Done. Remove the USB drive and reboot -> cfgloademmc finds cfgload on eMMC -> bootm boots Corebian."
echo "If it fails, plug the Corebian USB back in to boot normally (fallback)."
